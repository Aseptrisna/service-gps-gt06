# MongoDB (same database as TrackPro backend)
MONGODB_URI=mongodb://localhost:27017/fleet_monitoring

# TCP Server — port for GT06 GPS trackers to connect
TCP_HOST=0.0.0.0
TCP_PORT=8090

# WebSocket Server — real-time broadcasts to frontend
WS_PORT=8091
WS_CORS_ORIGIN=*

# Logging: error | warn | info | debug
LOG_LEVEL=info
